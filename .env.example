# Database (backend)
# SQLite default; for PostgreSQL use: postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=sqlite+aiosqlite:///./automeeting.db

# SMTP (optional; leave empty to skip sending email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=true

# Frontend API base (optional; dev uses Vite proxy /api -> backend)
# VITE_API_URL=http://127.0.0.1:8000
